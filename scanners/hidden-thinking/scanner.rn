use gage::{Ignore, write_note, write_issue, config, session, scan};

pub const SCANNER = #{
    name: "hidden-thinking",
    description: `
    Detect sessions where model thinking is hidden

    Thinking blocks provide important evidence of model thinking and
    should be visible. Unfortunately, the default settings for Claude
    Code cause thinking blocks to be hidden. This scanner looks for this
    consition and recommends fixes for issues it finds.
    `,

    tasks: #{
        check_thinking: #{
            context: "session",
            notes: #{
                writes: #{
                    "thinking.empty": #{
                        value: "true if thinking blocks are empty, false otherwise",
                        metadata: #{
                            timestamp: "Timestamp of msg",
                            model: "Model thinking block applies to",
                            config: "Applicable config at the time of writing",
                        },
                    },
                },
            },
        },
        issue: #{
            context: "scan",
            notes: #{
                wants: ["thinking.empty"],
                writes: #{
                    "thinking.empty.issue": #{
                        explanation: "Issue background info",
                    },
                },
            },
        },
    },
};

pub async fn check_thinking() {
    for msg in session()
        .messages()
        .with_type(#{ assistant: "thinking" })
        .reverse()
        .await?
    {
        let config = format!(
            "{{\"showThinkingSummaries\": {}}}",
            config().settings().await.get("showThinkingSummaries").unwrap_or("null")
        );
        write_note(
            #{
                name: "thinking.empty",
                value: msg.text == "",
                target: #{ line: msg.line },
                metadata: #{
                    msg_timestamp: msg.timestamp.millis(),
                    model: msg.model(),
                    config,
                },
            },
        )
        .keep_prev()
        .await?;
        break;
    }
    Ok(())
}

pub async fn issue() {
    // Use the most recent thinking.empty block for evidence
    let note = latest_evidence().await?.ok_or(Ignore)?;

    // Only report issues for empty text (value is true)
    if note.value {
        let timestamp = note.metadata.get("msg_timestamp").unwrap();
        write_issue(
            #{
                name: "hidden-thinking",
                title: "Thinking blocks hidden in recent session",
                description: "scanner:issue.md",
                evidence: [#{ note, timestamp }],
            },
        )
        .keep_status()
        .await?;
    }
    Ok(())
}

async fn latest_evidence() {
    let notes = scan().notes().with_name("thinking.empty").await?;
    if notes.is_empty() {
        return Ok(None);
    }
    let cmp = |a, b| {
        let a_ts = a.metadata.get("msg_timestamp").unwrap();
        let b_ts = b.metadata.get("msg_timestamp").unwrap();
        assert!(a_ts != 0 && b_ts != 0);
        b_ts.cmp(a_ts)
    };
    notes.sort_by(cmp);
    Ok(Some(notes[0]))
}
